# ╔══════════════════════════════════════════════════════════════════╗
# ║  .env — bu faylni nusxalab oling: cp .env.example .env             ║
# ║  Keyin pastdagi qiymatlarni O'Z Firebase loyihangizdan to'ldiring  ║
# ╚══════════════════════════════════════════════════════════════════╝

# ===== Server (maxfiy) — buyurtma uchun =====
# BotFather'dan olingan bot token
NUXT_BOT_TOKEN=123456789:AA...your-bot-token

# Buyurtmalar yuboriladigan admin/guruh chat id (masalan: 123456789 yoki -1001234567890)
NUXT_ADMIN_CHAT_ID=123456789

# (Ixtiyoriy) Buyurtmalarni server orqali Firestore'ga saqlash uchun service account JSON (bitta qatorda)
# NUXT_FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...", ...}

# ===== Public (klient) — Firebase Web config =====
# Bu qiymatlarni qayerdan olish kerak:
# Firebase Console → Project settings (⚙️) → "Your apps" → Web app → "SDK setup and configuration".
# DIQQAT: bu yer BO'SH qolsa yoki boshqa loyiha qiymatlari yozilsa, mahsulotlar
# SIZNING konsolingizda KO'RINMAYDI.
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
