rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // MAHSULOTLAR
    // - read: hammaga ochiq (do'kon mahsulotlarni ko'rsatishi uchun)
    // - create/update/delete: faqat admin (email/parol bilan kirgan).
    //   Reyting endi admin tomonidan oddiy update orqali qo'yiladi (mijoz emas).
    match /products/{productId} {
      allow read: if true;

      allow create, update, delete: if request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'password';
    }

    // BUYURTMALAR
    // - create: mijoz buyurtma bera oladi (mijozlar tizimga kirmaydi, shuning uchun auth shart emas)
    // - read/update/delete: faqat admin (email/parol bilan kirgan)
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'password';
    }

    // BANNERLAR
    // - read: hamma (Hero slayder uchun)
    // - create/update/delete: faqat admin
    match /banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'password';
    }

    // RO'YXATDAN O'TISH (So'rovnomalar)
    // - create: har kim forma to'ldira oladi (autentifikatsiya shart emas)
    // - read/delete: faqat admin
    match /registrations/{regId} {
      allow create: if true;
      allow read, delete: if request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'password';
    }

    // Boshqa hamma narsa — taqiq
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
