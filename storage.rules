rules_version = '2';

// Firebase Storage qoidalari.
// Console -> Storage -> Rules ga shu mazmunni qo'yib, Publish bosing.
// (Yoki: firebase deploy --only storage)
service firebase.storage {
  match /b/{bucket}/o {

    // MAHSULOT RASMLARI
    // - read: hammaga ochiq (do'kon rasmlarni ko'rsatishi uchun)
    // - write: faqat tizimga kirgan admin (Firebase Auth) yuklay oladi
    //   va fayl 5MB dan oshmasligi + rasm bo'lishi shart.
    match /products/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Boshqa hamma narsa — taqiq
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
